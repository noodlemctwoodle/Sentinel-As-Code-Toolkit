{
  "name": "sentinelcodeguard",
  "displayName": "Sentinel as Code Toolkit",
  "description": "The dedicated VS Code toolkit for the Sentinel-as-Code project: intelligent validation, formatting, templates, and ARM-to-YAML conversion for Microsoft Sentinel Analytics Rules",
  "version": "26.7.3",
  "publisher": "noodlemctwoodle",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Linters",
    "Formatters",
    "Snippets",
    "Programming Languages"
  ],
  "keywords": [
    "sentinel",
    "microsoft",
    "azure",
    "security",
    "analytics",
    "rules",
    "yaml",
    "validation",
    "kql",
    "mitre",
    "attack",
    "sentinel-as-code",
    "detection",
    "threat-hunting"
  ],
  "homepage": "https://sentinel.blog",
  "repository": {
    "type": "git",
    "url": "https://github.com/noodlemctwoodle/Sentinel-As-Code-Toolkit"
  },
  "bugs": {
    "url": "https://github.com/noodlemctwoodle/Sentinel-As-Code/issues"
  },
  "license": "Apache-2.0",
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:yaml",
    "onLanguage:json"
  ],
  "contributes": {
    "commands": [
      {
        "command": "sentinelAsCode.fixFieldOrder",
        "title": "Fix Field Order",
        "category": "Sentinel-As-Code"
      },
      {
        "command": "sentinelAsCode.formatRule",
        "title": "Format Sentinel Rule",
        "category": "Sentinel-As-Code"
      },
      {
        "command": "sentinelAsCode.formatContent",
        "title": "Format Sentinel Content (Auto-detect)",
        "category": "Sentinel-As-Code"
      },
      {
        "command": "sentinelAsCode.createSentinelRule",
        "title": "Create Sentinel Rule Template...",
        "category": "Sentinel-As-Code"
      },
      {
        "command": "sentinelAsCode.generateRuleTemplate",
        "title": "Generate Rule Template",
        "category": "Sentinel-As-Code"
      },
      {
        "command": "sentinelAsCode.regenerateGuid",
        "title": "Generate New Rule ID",
        "category": "Sentinel-As-Code"
      },
      {
        "command": "sentinelAsCode.regenerateAllGuids",
        "title": "Generate New IDs for All Rules",
        "category": "Sentinel-As-Code"
      },
      {
        "command": "sentinelAsCode.generateTemplate",
        "title": "Generate Standard Rule Template",
        "category": "Sentinel-As-Code"
      },
      {
        "command": "sentinelAsCode.generateNRTTemplate",
        "title": "Generate NRT Rule Template",
        "category": "Sentinel-As-Code"
      },
      {
        "command": "defender.generateDetectionTemplate",
        "title": "Generate Custom Detection Template",
        "category": "Defender-As-Code"
      },
      {
        "command": "sentinelAsCode.createWatchlistFromCsv",
        "title": "Create Watchlist from CSV",
        "category": "Sentinel-As-Code"
      },
      {
        "command": "sentinelAsCode.newContent",
        "title": "New Sentinel-as-Code Content...",
        "category": "Sentinel-As-Code"
      },
      {
        "command": "sentinelAsCode.createHuntingQuery",
        "title": "New Hunting Query",
        "category": "Sentinel-As-Code"
      },
      {
        "command": "sentinelAsCode.createParser",
        "title": "New Parser",
        "category": "Sentinel-As-Code"
      },
      {
        "command": "sentinelAsCode.createSummaryRule",
        "title": "New Summary Rule",
        "category": "Sentinel-As-Code"
      },
      {
        "command": "sentinelAsCode.createAutomationRule",
        "title": "New Automation Rule",
        "category": "Sentinel-As-Code"
      },
      {
        "command": "sentinelAsCode.populateDataConnectors",
        "title": "Populate Required Data Connectors from Query",
        "category": "Sentinel-As-Code"
      },
      {
        "command": "sentinelAsCode.validateWorkspace",
        "title": "Bulk Maintenance & Validation",
        "category": "Sentinel-As-Code"
      },
      {
        "command": "sentinelAsCode.convertArmToYaml",
        "title": "Decompile ARM to YAML",
        "category": "Sentinel-As-Code"
      },
      {
        "command": "sentinelAsCode.convertContentToJson",
        "title": "Convert Content YAML to JSON",
        "category": "Sentinel-As-Code"
      },
      {
        "command": "sentinelAsCode.convertContentToYaml",
        "title": "Convert Content JSON to YAML",
        "category": "Sentinel-As-Code"
      },
      {
        "command": "defender.formatForRepo",
        "title": "Format Custom Detection for Repo",
        "category": "Defender-As-Code"
      },
      {
        "command": "defender.convertYamlToJson",
        "title": "Convert Custom Detection YAML to JSON",
        "category": "Defender-As-Code"
      },
      {
        "command": "defender.convertJsonToYaml",
        "title": "Convert Custom Detection JSON to YAML",
        "category": "Defender-As-Code"
      },
      {
        "command": "sentinelAsCode.validateRule",
        "title": "Validate Rule (Auto-detect Type)",
        "category": "Sentinel-As-Code"
      },
      {
        "command": "sentinelAsCode.validateSentinelRule",
        "title": "Validate as Sentinel Analytics Rule",
        "category": "Sentinel-As-Code"
      },
      {
        "command": "defender.validateDetection",
        "title": "Validate as Custom Detection",
        "category": "Defender-As-Code"
      }
    ],
    "languages": [
      {
        "id": "sentinel-rule",
        "aliases": [
          "Sentinel Analytics Rule",
          "sentinel-rule"
        ],
        "extensions": [
          ".sentinel.yaml",
          ".sentinel.yml"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "sentinel-rule",
        "scopeName": "source.yaml.sentinel",
        "path": "./syntaxes/sentinel-rule.tmGrammar.json"
      }
    ],
    "snippets": [
      {
        "language": "sentinel-rule",
        "path": "./snippets/sentinel-rules.json"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "resourceExtname == .yaml && resourceFilename =~ /.*\\.sentinel\\.(yaml|yml)$/",
          "command": "sentinelAsCode.fixFieldOrder",
          "group": "sentinel@1"
        },
        {
          "when": "resourceExtname == .yaml && resourceFilename =~ /.*\\.sentinel\\.(yaml|yml)$/",
          "command": "sentinelAsCode.formatRule",
          "group": "sentinel@2"
        },
        {
          "when": "resourceExtname == .yaml || resourceExtname == .yml",
          "command": "sentinelAsCode.regenerateGuid",
          "group": "sentinel@3"
        },
        {
          "when": "resourceExtname == .json && config.sentinelAsCode.conversion.enabled",
          "command": "sentinelAsCode.convertArmToYaml",
          "group": "sentinel@4"
        },
        {
          "when": "resourceExtname == .yaml || resourceExtname == .yml || resourceExtname == .json",
          "command": "sentinelAsCode.formatContent",
          "group": "sentinel@5"
        },
        {
          "when": "resourceExtname == .csv || resourceExtname == .tsv",
          "command": "sentinelAsCode.createWatchlistFromCsv",
          "group": "sentinel@6"
        },
        {
          "when": "resourceExtname == .yaml || resourceExtname == .yml",
          "command": "sentinelAsCode.populateDataConnectors",
          "group": "sentinel@7"
        },
        {
          "when": "resourceExtname == .yaml || resourceExtname == .yml",
          "command": "sentinelAsCode.convertContentToJson",
          "group": "sentinel@8"
        },
        {
          "when": "resourceExtname == .json",
          "command": "sentinelAsCode.convertContentToYaml",
          "group": "sentinel@9"
        }
      ],
      "explorer/context": [
        {
          "when": "explorerResourceIsFolder",
          "command": "sentinelAsCode.newContent",
          "group": "sentinel@1"
        },
        {
          "when": "resourceExtname == .yaml || resourceExtname == .yml",
          "command": "sentinelAsCode.regenerateGuid",
          "group": "sentinel@2"
        },
        {
          "when": "resourceExtname == .json && config.sentinelAsCode.conversion.enabled",
          "command": "sentinelAsCode.convertArmToYaml",
          "group": "sentinel@3"
        },
        {
          "when": "resourceExtname == .yaml || resourceExtname == .yml",
          "command": "sentinelAsCode.convertContentToJson",
          "group": "sentinel@4"
        },
        {
          "when": "resourceExtname == .json",
          "command": "sentinelAsCode.convertContentToYaml",
          "group": "sentinel@5"
        }
      ],
      "commandPalette": [
        {
          "command": "sentinelAsCode.fixFieldOrder",
          "when": "resourceExtname == .yaml"
        },
        {
          "command": "sentinelAsCode.createSentinelRule",
          "when": "false"
        },
        {
          "command": "sentinelAsCode.generateRuleTemplate",
          "when": "false"
        },
        {
          "command": "sentinelAsCode.regenerateGuid",
          "when": "resourceExtname == .yaml"
        },
        {
          "command": "sentinelAsCode.regenerateAllGuids"
        },
        {
          "command": "sentinelAsCode.formatRule",
          "when": "resourceExtname == .yaml"
        },
        {
          "command": "sentinelAsCode.formatContent",
          "when": "resourceExtname == .yaml || resourceExtname == .yml || resourceExtname == .json"
        },
        {
          "command": "sentinelAsCode.validateWorkspace"
        },
        {
          "command": "sentinelAsCode.convertArmToYaml",
          "when": "config.sentinelAsCode.conversion.enabled"
        },
        {
          "command": "sentinelAsCode.convertContentToJson"
        },
        {
          "command": "sentinelAsCode.convertContentToYaml"
        },
        {
          "command": "sentinelAsCode.generateTemplate",
          "when": "false"
        },
        {
          "command": "sentinelAsCode.generateNRTTemplate",
          "when": "false"
        },
        {
          "command": "defender.generateDetectionTemplate",
          "when": "false"
        },
        {
          "command": "sentinelAsCode.createWatchlistFromCsv",
          "when": "resourceExtname == .csv || resourceExtname == .tsv"
        },
        {
          "command": "sentinelAsCode.newContent"
        },
        {
          "command": "sentinelAsCode.createHuntingQuery",
          "when": "false"
        },
        {
          "command": "sentinelAsCode.createParser",
          "when": "false"
        },
        {
          "command": "sentinelAsCode.createSummaryRule",
          "when": "false"
        },
        {
          "command": "sentinelAsCode.createAutomationRule",
          "when": "false"
        },
        {
          "command": "sentinelAsCode.populateDataConnectors",
          "when": "resourceExtname == .yaml || resourceExtname == .yml"
        }
      ]
    },
    "keybindings": [
      {
        "command": "sentinelAsCode.fixFieldOrder",
        "key": "ctrl+shift+f",
        "mac": "cmd+shift+f",
        "when": "resourceExtname == .yaml && resourceFilename =~ /.*\\.sentinel\\.(yaml|yml)$/"
      }
    ],
    "configuration": {
      "title": "Sentinel as Code Toolkit",
      "properties": {
        "sentinelAsCode.validation.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable automatic validation of Sentinel rules"
        },
        "sentinelAsCode.validation.onSave": {
          "type": "boolean",
          "default": true,
          "description": "Validate rules automatically on save"
        },
        "sentinelAsCode.validation.onType": {
          "type": "boolean",
          "default": false,
          "description": "Validate rules as you type (may impact performance)"
        },
        "sentinelAsCode.validation.excludePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Glob patterns for files to exclude from validation (for example: **/test/**, **/*.draft.yaml, **/.archive/**). Matching files show no diagnostics. Supports *, **, ?, and {a,b} alternation."
        },
        "sentinelAsCode.formatting.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable automatic formatting of Sentinel rules"
        },
        "sentinelAsCode.fieldOrdering.enforceOrder": {
          "type": "boolean",
          "default": true,
          "description": "Enforce proper field ordering in Sentinel rules"
        },
        "sentinelAsCode.fieldOrdering.showOrderHints": {
          "type": "boolean",
          "default": true,
          "description": "Show field ordering hints in diagnostics"
        },
        "sentinelAsCode.intellisense.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable IntelliSense for Sentinel rule fields"
        },
        "sentinelAsCode.mitre.version": {
          "type": "string",
          "default": "v16",
          "enum": [
            "v16",
            "v15",
            "v14"
          ],
          "description": "MITRE ATT&CK framework version to use for validation"
        },
        "sentinelAsCode.mitre.frameworks": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "enterprise",
              "mobile",
              "ics"
            ]
          },
          "default": [
            "enterprise",
            "mobile",
            "ics"
          ],
          "description": "MITRE ATT&CK frameworks to load and validate against"
        },
        "sentinelAsCode.connectors.validationMode": {
          "type": "string",
          "enum": [
            "strict",
            "workspace",
            "permissive"
          ],
          "default": "permissive",
          "enumDescriptions": [
            "Only allow known connectors from extension database",
            "Allow connectors defined in workspace .sentinel-connectors.json",
            "Allow any valid connector ID format (recommended)"
          ],
          "description": "How strictly to validate connector IDs"
        },
        "sentinelAsCode.connectors.customConnectors": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional custom connector IDs to recognize"
        },
        "sentinelAsCode.mitre.allowUnknownTactics": {
          "type": "boolean",
          "default": true,
          "description": "Allow tactics not found in loaded MITRE data (shows info message only)"
        },
        "sentinelAsCode.mitre.allowUnknownTechniques": {
          "type": "boolean",
          "default": true,
          "description": "Allow techniques not found in loaded MITRE data (shows info message only)"
        },
        "sentinelAsCode.mitre.strictValidation": {
          "type": "boolean",
          "default": false,
          "description": "Require all tactics/techniques to be in loaded MITRE data (shows errors for unknown items)"
        },
        "sentinelAsCode.conversion.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable ARM template to YAML conversion functionality"
        },
        "sentinelAsCode.conversion.defaultNamingStrategy": {
          "type": "string",
          "enum": [
            "original",
            "displayName",
            "ruleId"
          ],
          "default": "displayName",
          "enumDescriptions": [
            "Use original filename with .yaml extension",
            "Use rule's displayName property as filename",
            "Use rule's unique identifier as filename"
          ],
          "description": "Default strategy for naming converted YAML files"
        },
        "sentinelAsCode.conversion.validateMitreOnConversion": {
          "type": "boolean",
          "default": true,
          "description": "Validate and correct MITRE tactics/techniques during conversion"
        },
        "sentinelAsCode.conversion.autoFormatAfterConversion": {
          "type": "boolean",
          "default": true,
          "description": "Automatically format converted YAML files using Sentinel as Code Toolkit formatting"
        },
        "sentinelAsCode.conversion.showConversionSummary": {
          "type": "boolean",
          "default": true,
          "description": "Show conversion summary dialog with warnings and results"
        },
        "sentinelAsCode.conversion.outputDirectory": {
          "type": "string",
          "default": "",
          "description": "Custom output directory for converted files (empty = same directory as source)"
        },
        "sentinelAsCode.conversion.preserveQueryFormatting": {
          "type": "boolean",
          "default": true,
          "description": "Preserve original KQL query formatting in converted YAML"
        },
        "sentinelAsCode.conversion.includeOptionalFields": {
          "type": "boolean",
          "default": true,
          "description": "Include optional fields with default values in converted YAML"
        },
        "sentinelAsCode.conversion.validateEntityMappings": {
          "type": "boolean",
          "default": true,
          "description": "Validate entity types and identifiers during conversion"
        },
        "sentinelAsCode.conversion.defaultVersion": {
          "type": "string",
          "default": "1.0.0",
          "description": "Default version for rules missing templateVersion in ARM template"
        }
      }
    },
    "jsonValidation": [
      {
        "fileMatch": "*.sentinel.yaml",
        "url": "./schemas/sentinel-analytics-rule-schema.json"
      },
      {
        "fileMatch": "*.sentinel.yml",
        "url": "./schemas/sentinel-analytics-rule-schema.json"
      },
      {
        "fileMatch": "**/AnalyticalRules/**/*.yaml",
        "url": "./schemas/sentinel-analytics-rule-schema.json"
      },
      {
        "fileMatch": "**/HuntingQueries/**/*.yaml",
        "url": "./schemas/sentinel-hunting-query-schema.json"
      },
      {
        "fileMatch": "**/HuntingQueries/**/*.yml",
        "url": "./schemas/sentinel-hunting-query-schema.json"
      },
      {
        "fileMatch": "**/Parsers/**/*.yaml",
        "url": "./schemas/sentinel-parser-schema.json"
      },
      {
        "fileMatch": "**/Parsers/**/*.yml",
        "url": "./schemas/sentinel-parser-schema.json"
      },
      {
        "fileMatch": "**/SummaryRules/**/*.json",
        "url": "./schemas/sentinel-summary-rule-schema.json"
      },
      {
        "fileMatch": "**/AutomationRules/**/*.json",
        "url": "./schemas/sentinel-automation-rule-schema.json"
      },
      {
        "fileMatch": "**/Watchlists/**/watchlist.json",
        "url": "./schemas/sentinel-watchlist-schema.json"
      },
      {
        "fileMatch": "**/DefenderCustomDetections/**/*.yaml",
        "url": "./schemas/defender-custom-detection-schema.json"
      },
      {
        "fileMatch": "**/DefenderCustomDetections/**/*.yml",
        "url": "./schemas/defender-custom-detection-schema.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run webpack",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "webpack": "webpack --mode production --devtool hidden-source-map",
    "webpack-dev": "webpack --mode development --watch",
    "compile-tests": "tsc -p . --outDir out",
    "clean": "rimraf out",
    "pretest": "npm run clean && npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext ts --fix",
    "lint:check": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.1.1",
    "@types/vscode": "^1.125.0",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "eslint": "^10.6.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.6",
    "rimraf": "^6.1.3",
    "ts-loader": "^9.6.2",
    "typescript": "~6.0.3",
    "webpack": "^5.108.4",
    "webpack-cli": "^7.2.1"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "jsonschema": "^1.5.0",
    "tmp": "^0.2.7",
    "uuid": "^14.0.1"
  },
  "overrides": {
    "form-data": "^4.0.6",
    "serialize-javascript": "^7.0.7",
    "diff": "^9.0.0"
  }
}
